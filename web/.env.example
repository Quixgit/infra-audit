# Google OAuth — скопируй этот файл в .env и заполни значения
# Инструкция: https://console.cloud.google.com/apis/credentials

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Redirect URI — должен совпадать с тем что прописан в Google Console
GOOGLE_REDIRECT_URL=http://23.19.228.158:3000/api/auth/google/callback
